-- @LEDGER run ExternalCallBytesHexPolicy.EXPECTED.ledger

module ExternalCallBytesHexPolicy where

import Daml.Script
import DA.External

run : Script Bool
run = script do
  pure (isBytesHex "0a" && not (isBytesHex "0A") && not (isBytesHex "abc"))
